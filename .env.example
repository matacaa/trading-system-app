# ─── Variables de entorno — copia este archivo como .env ───
# cp .env.example .env  →  luego rellena con tus valores reales
# ───────────────────────────────────────────────────────────

# Supabase (obligatorio)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=eyJhbGciOi...tu-clave-aqui

# Alpaca (obligatorio)
ALPACA_API_KEY=PK...tu-api-key
ALPACA_SECRET_KEY=...tu-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# HuggingFace (obligatorio — para descargar FinBERT)
HUGGINGFACE_TOKEN=hf_...tu-token

# Seguridad (no tocar a menos que sepas lo que haces)
ALLOW_LIVE_TRADING=false

# Opcional
BATCH_INSERT=500
